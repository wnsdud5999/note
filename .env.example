# sha256 hex of "PASSWORD_SALT:your-password"
# Example generation:
# node -e "const c=require('crypto');console.log(c.createHash('sha256').update('change-this-salt:your-password').digest('hex'))"
EDITOR_PASSWORD_HASH=

# Change this salt
PASSWORD_SALT=change-this-salt

# Use a long random value in production
SESSION_SECRET=replace-this-with-a-long-random-string

PORT=3000
